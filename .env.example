# Public — exposed to the browser
NEXT_PUBLIC_SITE_URL=https://vpbuyshomes.com

# Mapbox Geocoding — powers the address-autocomplete dropdown on the lead form.
# Optional: if unset, the address field degrades gracefully to a plain text input.
# 1. Sign up at https://account.mapbox.com → create a "public" access token
# 2. Restrict the token to URLs: vpbuyshomes.com, *.vercel.app, localhost:*
# 3. Free tier is 100,000 requests/month — well above expected lead volume
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend — lead notification emails
# https://resend.com/api-keys
# IMPORTANT: if you have NOT yet verified vpbuyshomes.com in Resend, sends from
# leads@vpbuyshomes.com will fail. The app will automatically retry from
# onboarding@resend.dev (Resend's sandbox) so you still receive leads while DNS
# propagates. Verify the domain in Resend Dashboard → Domains to remove the fallback.
RESEND_API_KEY=

# Where lead notifications are sent. Defaults to traver97@gmail.com if unset.
LEAD_NOTIFICATION_EMAIL=traver97@gmail.com

# Google Sheets — lead log (optional; if any var is missing we fall back to
# writing .data/leads.json on the server disk).
# Set up: console.cloud.google.com → create service account → download JSON key
# → share the target Sheet with the service account email as Editor.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_TITLE=Leads

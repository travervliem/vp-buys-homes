# Public — exposed to the browser
NEXT_PUBLIC_SITE_URL=https://www.vpbuyshomes.com

# Mapbox Geocoding — powers the address-autocomplete dropdown on the lead form.
# Optional: if unset, the address field degrades gracefully to a plain text input.
# 1. Sign up at https://account.mapbox.com → create a "public" access token
# 2. Restrict the token to URLs: vpbuyshomes.com, *.vercel.app, localhost:*
# 3. Free tier is 100,000 requests/month — well above expected lead volume
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend — lead notification emails
# https://resend.com/api-keys
# IMPORTANT: if you have NOT yet verified vpbuyshomes.com in Resend, sends from
# leads@vpbuyshomes.com will fail. The app will automatically retry from
# onboarding@resend.dev (Resend's sandbox) so you still receive leads while DNS
# propagates. Verify the domain in Resend Dashboard → Domains to remove the fallback.
RESEND_API_KEY=

# Where lead notifications are sent. Defaults to traver97@gmail.com if unset.
LEAD_NOTIFICATION_EMAIL=traver97@gmail.com

# Google Sheets — lead log via a Google Apps Script web app webhook.
# Optional; if unset, leads fall back to writing .data/leads.json on the server.
# Set up:
#  1. Create a Google Sheet
#  2. Extensions → Apps Script → paste the doPost handler (see docs/sheets-webhook.gs or README)
#  3. Deploy → Web app → Execute as: Me, Access: Anyone
#  4. Copy the /exec URL here
SHEETS_WEBHOOK_URL=

# Google Search Console — powers `npm run gsc:check` (local-only tool).
# One-time setup:
#  1. Keep the OAuth client JSON downloaded from Google Cloud Console (Desktop app)
#     stored outside the repo, e.g. ~/.config/vpbuyshomes/oauth-client.json
#  2. Run `npm run gsc:auth /path/to/oauth-client.json` — it opens a browser,
#     you grant consent, and it prints these env values for you to paste here.
#  3. Then `npm run gsc:check` will print sitemap status, index coverage, and
#     top queries/pages from the last 7 days.
# Property URL format must match exactly what's in Search Console:
#   Domain property:     sc-domain:vpbuyshomes.com
#   URL-prefix property: https://vpbuyshomes.com/
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
GSC_SITE_URL=https://vpbuyshomes.com/
